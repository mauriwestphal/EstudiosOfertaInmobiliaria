# Variables de entorno para Workers de Cloudflare
# Copiar este archivo y rellenar con valores reales

# ============================================
# rw-intake worker
# ============================================

# API key de Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# KV namespace ID (crear en Cloudflare KV)
ESTUDIOS_KV=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clave secreta para autenticación admin
ADMIN_SECRET=tu_clave_secreta_aqui

# ============================================
# rw-publish worker  
# ============================================

# Personal Access Token de GitHub con permisos repo:write
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Dueño del repositorio
GITHUB_OWNER=mauriwestphal

# Nombre del repositorio
GITHUB_REPO=EstudiosOfertaInmobiliaria

# API key de Resend para emails
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email remitente (debe estar verificado en Resend)
EMAIL_FROM=estudios@rwconsulting.cl

# Misma clave secreta que rw-intake
ADMIN_SECRET=tu_clave_secreta_aqui

# ============================================
# rw-consulting-chat worker (existente)
# ============================================

# Misma API key de Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Códigos de estudios válidos (separados por coma)
VALID_CODES=EST-2026-KI-4V7P,EST-2026-GV-9X2M

# ============================================
# Instrucciones
# ============================================

# 1. Copiar este archivo como `.env` (sin .example)
# 2. Rellenar todos los valores con datos reales
# 3. Configurar en Cloudflare Workers como Environment Variables
# 4. Para admin.html, usar: ?admin_secret=tu_clave_secreta_aqui

# NOTA: Nunca commitar archivos `.env` con valores reales al repositorio